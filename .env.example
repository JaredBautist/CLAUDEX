# Optional runtime configuration for Claudex
# Copy to .env.local and export variables in your shell profile as needed.

# OpenClaw gateway endpoint
UPSTREAM_URL=http://127.0.0.1:18789

# Upstream model name
# Examples: gpt-5.4, gemini-*, grok-*, kimi-*, llama*/qwen* (via Ollama)
UPSTREAM_MODEL=openclaw

# Upstream auth token (required only if your gateway enforces auth)
UPSTREAM_AUTH=

# Optional fixed proxy port (launcher auto-selects a free port if omitted)
PROXY_PORT=
